# ============================================
# Kafka — Chạy local hoặc trên server
# Nếu Kafka chạy cùng máy: localhost:9092
# Nếu Kafka chạy máy khác: <IP_SERVER>:9092
# ============================================
KAFKA_BROKER_URL=localhost:9092

# ============================================
# ChromaDB Cloud (Vector Database)
# ============================================
CHROMADB_MODE=cloud
CHROMADB_API_KEY=your_chromadb_api_key_here
CHROMADB_TENANT=your_chromadb_tenant_id_here
CHROMADB_DATABASE=fin-sent-database
CHROMADB_COLLECTION=macro_policies

# ============================================
# HuggingFace & AI Models
# ============================================
HUGGINGFACE_API_KEY=your_huggingface_token_here

# ============================================
# Data Paths — dùng đường dẫn tuyệt đối trên server
# Ví dụ: /home/user/FinSeg-System/data-pipeline/data/facebook_mock_shb.csv
# Hoặc để mặc định nếu chạy đúng từ thư mục data_pipeline_ingestion/
# ============================================
SHB_DATASET_PATH=./data/facebook_mock_shb.csv
SCB_DATASET_PATH=./data/facebook_mock_scb.csv
NHNN_DOCS_PATH=./data/nhnn_docs_SCB
SHB_DOCS_PATH=./data/shb

# ============================================
# Replay Service & Logging
# ============================================
REPLAY_RATE_LIMIT=1
LOG_LEVEL=INFO
DEVELOPMENT_MODE=true

# ============================================
# Realtime Pipeline Settings
# ============================================
# Chu ky crawl va tinh VMSI (giay, mac dinh 1800 = 30 phut)
CRAWL_INTERVAL_SECONDS=1800
VMSI_CYCLE_SECONDS=1800

# Khoang thoi gian lay du lieu lich su (thang 4 → thang 6 hien tai)
HISTORY_START_DATE=2025-04-01
HISTORY_END_DATE=2026-06-30

# ChromaDB collection rieng cho realtime (khong ghi de collection demo)
CHROMA_REALTIME_COLLECTION=realtime_policies

# Facebook credentials (bat buoc de crawl that)
# Neu khong co, he thong chay o che do STUB (du lieu mau)
FB_EMAIL=your_facebook_email@example.com
FB_PASSWORD=your_facebook_password
# Hoac dung cookie file (xuat tu browser)
# FB_COOKIE_FILE=/path/to/fb_cookies.json
